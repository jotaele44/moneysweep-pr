{
  "version": "1.0",
  "schema_version": "r5_schema_registry_v1",
  "canonical_columns": {
    "entity_id": {
      "dtype": "string",
      "required": true,
      "description": "Unique resolved-entity id; UEI when present, else hashed normalized_name."
    },
    "parent_uei": {
      "dtype": "string",
      "required": false,
      "description": "SAM ultimate parent UEI."
    },
    "uei": {
      "dtype": "string",
      "required": false,
      "description": "SAM UEI of the entity itself."
    },
    "duns": {
      "dtype": "string",
      "required": false,
      "description": "Legacy DUNS."
    },
    "cage": {
      "dtype": "string",
      "required": false,
      "description": "CAGE code."
    },
    "normalized_name": {
      "dtype": "string",
      "required": true,
      "description": "Legal-suffix-stripped, alphanumeric-cleaned name."
    },
    "raw_name": {
      "dtype": "string",
      "required": true,
      "description": "Original name as ingested."
    },
    "award_id": {
      "dtype": "string",
      "required": false,
      "description": "Prime award id (USAspending generated_unique_award_id or FPDS PIID)."
    },
    "contract_number": {
      "dtype": "string",
      "required": false,
      "description": "Territorial contract number where USAspending id is not available."
    },
    "subaward_id": {
      "dtype": "string",
      "required": false,
      "description": "FSRS / USAspending subaward id."
    },
    "funding_source": {
      "dtype": "string",
      "required": false,
      "description": "Federal/territorial funding stream name."
    },
    "awarding_agency": {
      "dtype": "string",
      "required": false,
      "description": "Agency that issued the award."
    },
    "obligation_amount": {
      "dtype": "float64",
      "required": false,
      "description": "Federal obligated amount in USD."
    },
    "outlay_amount": {
      "dtype": "float64",
      "required": false,
      "description": "Federal outlay amount in USD."
    },
    "award_date": {
      "dtype": "date",
      "required": false,
      "description": "Award action date."
    },
    "start_date": {
      "dtype": "date",
      "required": false,
      "description": "Period of performance start."
    },
    "end_date": {
      "dtype": "date",
      "required": false,
      "description": "Period of performance end."
    },
    "project_id": {
      "dtype": "string",
      "required": false,
      "description": "Project / PW / activity id."
    },
    "asset_id": {
      "dtype": "string",
      "required": false,
      "description": "Operational asset id (treatment plant, dam, road, etc.)."
    },
    "asset_name": {
      "dtype": "string",
      "required": false,
      "description": "Human-readable asset name."
    },
    "asset_type": {
      "dtype": "string",
      "required": false,
      "description": "Asset taxonomy: dam, wtp, wwtp, road, bridge, port, airport, grid, etc."
    },
    "municipality": {
      "dtype": "string",
      "required": false,
      "description": "PR municipality."
    },
    "geo_location": {
      "dtype": "string",
      "required": false,
      "description": "WKT/lat,lon or '' if unknown."
    },
    "geo_municipality_code": {
      "dtype": "string",
      "required": false,
      "description": "5-digit PR county FIPS (e.g. 72127 San Juan). Populated by post_ingest.apply_post_ingest()."
    },
    "geo_municipality_name": {
      "dtype": "string",
      "required": false,
      "description": "Canonical English PR municipality name. Joined from data/reference/pr_municipalities.csv."
    },
    "geo_county_fips": {
      "dtype": "string",
      "required": false,
      "description": "PR county FIPS (same as municipality_code in PR)."
    },
    "geo_zip": {
      "dtype": "string",
      "required": false,
      "description": "ZIP code if the source provides one, else blank."
    },
    "geo_lat": {
      "dtype": "string",
      "required": false,
      "description": "Latitude if the source provides one, else blank."
    },
    "geo_lon": {
      "dtype": "string",
      "required": false,
      "description": "Longitude if the source provides one, else blank."
    },
    "geo_attribution_source": {
      "dtype": "string",
      "required": false,
      "description": "Input column name that produced the match."
    },
    "geo_attribution_confidence": {
      "dtype": "string",
      "required": false,
      "description": "exact_fips | exact_name | normalized_name | fuzzy_name | unknown."
    },
    "source_system": {
      "dtype": "string",
      "required": true,
      "description": "source_id from source_registry.yaml."
    },
    "source_file": {
      "dtype": "string",
      "required": true,
      "description": "Repo-relative path of the staged file."
    },
    "source_url": {
      "dtype": "string",
      "required": false,
      "description": "Public/authorized URL from which this row was ingested."
    },
    "source_hash": {
      "dtype": "string",
      "required": true,
      "description": "sha256 of the source file at ingest time."
    },
    "link_confidence": {
      "dtype": "float64",
      "required": false,
      "description": "0.0-1.0 confidence on join evidence."
    },
    "resolution_method": {
      "dtype": "string",
      "required": false,
      "description": "How the entity was resolved: parent_field_or_sam_index, uei_no_parent, observed_only, manual_review."
    },
    "ingestion_timestamp": {
      "dtype": "timestamp",
      "required": true,
      "description": "UTC ISO ingest time."
    }
  },
