# Copy this file to .env and fill in your real keys.
# .env is gitignored — it will never be committed.
#
# Required — pipeline steps fail without this:
#   SAM.gov API key: https://sam.gov/data-services (free, instant)
SAM_API_KEY=paste_your_key_here

# Required for LDA lobbying enrichment (step 18b):
#   Register at https://lda.senate.gov/api (free)
LDA_API_KEY=paste_your_key_here

# Recommended — DEMO_KEY caps at 1,000 FEC records; real key gets ~5,700:
#   Register at https://api.data.gov/signup (free, instant)
FEC_API_KEY=paste_your_key_here

# Optional — OpenCorporates business registry cross-check:
#   Register at https://opencorporates.com/api_accounts/new
OPENCORPORATES_API_TOKEN=paste_your_key_here
