# Copy this file to .env and fill in your real keys.
# .env is gitignored — it will never be committed.
#
# Required — pipeline steps fail without this:
#   SAM.gov API key: https://sam.gov/data-services (free, instant)
SAM_API_KEY=paste_your_key_here

# Required for LDA lobbying enrichment (step 18b):
#   Register at https://lda.senate.gov/api (free)
LDA_API_KEY=paste_your_key_here

# Recommended — DEMO_KEY caps at 1,000 FEC records; real key gets ~5,700:
#   Register at https://api.data.gov/signup (free, instant)
FEC_API_KEY=paste_your_key_here

# Required for the Federal Audit Clearinghouse producer (federal_audit_clearinghouse):
#   Register at https://www.fac.gov / api.data.gov (free, instant)
FAC_API_KEY=paste_your_key_here

# DEPRECATED — OpenCorporates (paid API token) is no longer used. Its corporate
# identity / officers role is now filled by free, KEYLESS sources that need no
# entry here: gleif_lei (scripts/download_gleif.py), sec_officers
# (scripts/download_sec_officers.py), plus the operator-supplied
# pr_corporate_registry export. Leave this unset.
# OPENCORPORATES_API_TOKEN=

# Optional — HigherGov supplemental federal contract intel:
#   Register at https://www.highergov.com/api
HIGHERGOV_API_KEY=paste_your_key_here

# Optional — api.data.gov gateway key (a single key works across FEC, FAC, and
# other api.data.gov-fronted endpoints, sent as the X-Api-Key header):
#   Register at https://api.data.gov/signup/
DATA_GOV_API_KEY=paste_your_key_here

# Optional — Census Data API (gov-finances coverage-gap intake stub):
#   Register at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=paste_your_key_here

# Required for the EIA Open Data downloader (scripts/download_eia.py):
#   Register at https://www.eia.gov/opendata/register.php (free, instant)
EIA_API_KEY=paste_your_key_here

# Required for the FRED downloader (scripts/download_fred.py):
#   Register at https://fred.stlouisfed.org/docs/api/api_key.html (free, instant)
FRED_API_KEY=paste_your_key_here

# Optional — Felt map publishing for asset/control graph deliverables:
#   Register at https://felt.com/account/api
FELT_API_KEY=paste_your_key_here

# Optional commercial — FinancialData.net adapter (DISABLED BY DEFAULT).
# Live calls require BOTH the key below AND explicit license acknowledgement.
# Leave both unset (or LICENSE flag falsy) to keep the adapter in dry-run/mock
# mode. See docs/financialdata_provider.md.
FINANCIALDATA_API_KEY=
FINANCIALDATA_LICENSE_APPROVED=false

# Note: keys may also live in `Contract-Sweeper-Secrets/` outside the repo.
# Never commit real values. `.env` is gitignored; this file is only a template.

# Optional api.data.gov rate-limit key (sent as X-Api-Key to EPA ECHO etc.)
X_API_KEY=paste_your_key_here
