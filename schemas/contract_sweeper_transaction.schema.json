{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "contract_sweeper_transaction.schema.json",
  "title": "Contract-Sweeper Transaction",
  "description": "A monetary transaction (disbursement, obligation, reimbursement, etc.) between two entities.",
  "type": "object",
  "required": [
    "transaction_id",
    "source_id",
    "payer_entity_id",
    "payee_entity_id",
    "amount",
    "currency",
    "transaction_date",
    "transaction_type",
    "confidence",
    "lineage",
    "synthetic",
    "created_at",
    "extracted_at"
  ],
  "properties": {
    "transaction_id": {"type": "string", "pattern": "^txn_[a-f0-9]{32}$"},
    "source_id": {"type": "string", "pattern": "^src_[a-f0-9]{32}$"},
    "payer_entity_id": {"type": "string", "pattern": "^ent_[a-f0-9]{32}$"},
    "payee_entity_id": {"type": "string", "pattern": "^ent_[a-f0-9]{32}$"},
    "amount": {"type": "number", "minimum": 0.0},
    "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "transaction_date": {"type": "string", "format": "date"},
    "transaction_type": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "lineage": {"$ref": "#/definitions/lineage"},
    "synthetic": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "extracted_at": {"type": "string", "format": "date-time"}
  },
  "definitions": {
    "lineage": {
      "type": "object",
      "required": ["producer_script", "producer_phase", "source_inputs"],
      "properties": {
        "producer_script": {"type": "string"},
        "producer_phase": {"type": "string"},
        "source_inputs": {"type": "array", "items": {"type": "string"}},
        "extraction_method": {"type": "string"}
      }
    }
  }
}
