{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entity Alias Row",
  "type": "object",
  "required": [
    "alias_id",
    "entity_id",
    "alias",
    "source_id",
    "evidence_tier",
    "confidence"
  ],
  "properties": {
    "alias_id": {
      "type": "string",
      "pattern": "^ENT_ALIAS_[A-Za-z0-9_.:-]+$"
    },
    "entity_id": {
      "type": "string",
      "pattern": "^ENT_(ORG|PERSON|AGENCY|MUNI|PROJECT|CONTRACT|DEBT|PROPERTY|ASSET)_[A-Za-z0-9_.:-]+$"
    },
    "alias": {"type": "string", "minLength": 1},
    "normalized_alias": {"type": "string"},
    "source_id": {"type": "string", "minLength": 1},
    "evidence_tier": {"type": "string", "enum": ["T1", "T2", "T3", "T4"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
