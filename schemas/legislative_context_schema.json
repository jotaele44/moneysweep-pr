{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jotaele44/moneysweep-pr/schemas/legislative_context_schema.json",
  "title": "MoneySweep Puerto Rico Legislative Context Record",
  "type": "object",
  "required": [
    "source_id",
    "session_label",
    "measure_type",
    "measure_title",
    "status",
    "retrieved_at",
    "provenance_hash",
    "review_state"
  ],
  "properties": {
    "source_id": { "type": "string", "const": "legislapr_sessions_export" },
    "source_record_id": { "type": ["string", "null"] },
    "session_label": { "type": "string", "minLength": 1 },
    "measure_type": { "type": "string", "minLength": 1 },
    "measure_number": { "type": ["string", "null"] },
    "measure_title": { "type": "string", "minLength": 1 },
    "measure_summary": { "type": ["string", "null"] },
    "status": { "type": "string", "minLength": 1 },
    "introduced_date": { "type": ["string", "null"] },
    "latest_action_date": { "type": ["string", "null"] },
    "enacted_law_number": { "type": ["string", "null"] },
    "sponsors": { "type": ["string", "null"] },
    "committees": { "type": ["string", "null"] },
    "agency_mentions": { "type": ["string", "null"] },
    "appropriation_signal": { "type": ["boolean", "number", "null"] },
    "oversight_signal": { "type": ["boolean", "number", "null"] },
    "infrastructure_signal": { "type": ["boolean", "number", "null"] },
    "recovery_signal": { "type": ["boolean", "number", "null"] },
    "vendor_signal": { "type": ["boolean", "number", "null"] },
    "source_url": { "type": ["string", "null"] },
    "retrieved_at": { "type": "string", "minLength": 1 },
    "provenance_hash": { "type": "string", "minLength": 32 },
    "review_state": {
      "type": "string",
      "enum": ["staged", "needs_crosswalk", "crosswalk_confirmed", "rejected"]
    }
  },
  "additionalProperties": true
}
