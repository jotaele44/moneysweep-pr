{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical_v1/entities.schema.json",
  "title": "Canonical v1 — Entity",
  "description": "An organization (agency, firm, fund, nonprofit, utility) in Canonical Entity Relationship Model v1.",
  "type": "object",
  "required": ["entity_id", "name", "normalized_name", "entity_type", "confidence"],
  "properties": {
    "entity_id": {"type": "string", "pattern": "^entity_[A-Za-z0-9_]+$"},
    "name": {"type": "string", "minLength": 1},
    "normalized_name": {"type": "string", "minLength": 1},
    "entity_type": {"type": "string", "enum": ["agency", "firm", "fund", "nonprofit", "utility", "other"]},
    "parent_entity_id": {"type": "string", "pattern": "^entity_[A-Za-z0-9_]+$"},
    "jurisdiction": {"type": "string"},
    "registry_ids": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "evidence_id": {"type": "string", "pattern": "^evidence_[A-Za-z0-9_]+$"},
    "review_status": {"type": "string", "enum": ["accepted", "pending", "rejected"]},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
