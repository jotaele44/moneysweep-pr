{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical_v1/review_queue.schema.json",
  "title": "Canonical v1 — Review Queue Item",
  "description": "An unverified, ambiguous, or conflicting record routed for human review in Canonical Entity Relationship Model v1.",
  "type": "object",
  "required": ["review_id", "object_type", "issue_type", "status"],
  "properties": {
    "review_id": {"type": "string", "pattern": "^review_[A-Za-z0-9_]+$"},
    "object_type": {"type": "string"},
    "object_id": {"type": "string"},
    "issue_type": {"type": "string", "enum": ["ambiguous", "conflicting", "unverified", "missing_evidence", "low_confidence", "unknown_vocab", "broken_reference", "other"]},
    "raw_value": {"type": "string"},
    "candidate_match": {"type": "string"},
    "source_name": {"type": "string"},
    "source_ref": {"type": "string"},
    "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "recommended_action": {"type": "string"},
    "status": {"type": "string", "enum": ["open", "in_review", "resolved", "rejected"]}
  },
  "additionalProperties": true
}
