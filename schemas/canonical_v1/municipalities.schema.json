{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical_v1/municipalities.schema.json",
  "title": "Canonical v1 — Municipality",
  "description": "A Puerto Rico municipality geographic anchor in Canonical Entity Relationship Model v1.",
  "type": "object",
  "required": ["municipality_id", "name", "normalized_name"],
  "properties": {
    "municipality_id": {"type": "string", "pattern": "^muni_pr_[A-Za-z0-9_]+$"},
    "name": {"type": "string", "minLength": 1},
    "normalized_name": {"type": "string", "minLength": 1},
    "region": {"type": "string"},
    "county_fips": {"type": "string"},
    "aliases": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "evidence_id": {"type": "string", "pattern": "^evidence_[A-Za-z0-9_]+$"},
    "review_status": {"type": "string", "enum": ["accepted", "pending", "rejected"]},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
