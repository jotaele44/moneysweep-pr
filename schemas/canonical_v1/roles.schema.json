{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical_v1/roles.schema.json",
  "title": "Canonical v1 — Role",
  "description": "A person-to-institution position in Canonical Entity Relationship Model v1.",
  "type": "object",
  "required": ["role_id", "person_id", "entity_id", "role_category", "confidence"],
  "properties": {
    "role_id": {"type": "string", "pattern": "^role_[A-Za-z0-9_]+$"},
    "person_id": {"type": "string", "pattern": "^person_[A-Za-z0-9_]+$"},
    "entity_id": {"type": "string", "pattern": "^entity_[A-Za-z0-9_]+$"},
    "role_title": {"type": "string"},
    "role_category": {"type": "string", "enum": ["executive", "board", "officer", "agent", "advisor", "lobbyist", "other"]},
    "start_date": {"type": "string"},
    "end_date": {"type": "string"},
    "current": {"type": "boolean"},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "evidence_id": {"type": "string", "pattern": "^evidence_[A-Za-z0-9_]+$"},
    "review_status": {"type": "string", "enum": ["accepted", "pending", "rejected"]},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
