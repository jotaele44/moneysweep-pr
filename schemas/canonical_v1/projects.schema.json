{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical_v1/projects.schema.json",
  "title": "Canonical v1 — Project",
  "description": "An infrastructure, recovery, PPP, or real-estate project in Canonical Entity Relationship Model v1.",
  "type": "object",
  "required": ["project_id", "project_name", "project_type", "confidence"],
  "properties": {
    "project_id": {"type": "string", "pattern": "^project_[A-Za-z0-9_]+$"},
    "project_name": {"type": "string", "minLength": 1},
    "project_number": {"type": "string"},
    "project_type": {"type": "string", "enum": ["infrastructure", "recovery", "ppp", "real_estate", "other"]},
    "lead_entity_id": {"type": "string", "pattern": "^entity_[A-Za-z0-9_]+$"},
    "municipality_id": {"type": "string", "pattern": "^muni_pr_[A-Za-z0-9_]+$"},
    "funding_source_id": {"type": "string", "pattern": "^funding_[A-Za-z0-9_]+$"},
    "total_value": {"type": "number", "minimum": 0.0},
    "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "status": {"type": "string"},
    "start_date": {"type": "string"},
    "end_date": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "evidence_id": {"type": "string", "pattern": "^evidence_[A-Za-z0-9_]+$"},
    "review_status": {"type": "string", "enum": ["accepted", "pending", "rejected"]},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
