{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical_v1/evidence.schema.json",
  "title": "Canonical v1 — Evidence",
  "description": "A first-class, source-backed claim in Canonical Entity Relationship Model v1.",
  "type": "object",
  "required": ["evidence_id", "source_type", "source_name", "claim", "evidence_tier", "confidence", "review_status"],
  "properties": {
    "evidence_id": {"type": "string", "pattern": "^evidence_[A-Za-z0-9_]+$"},
    "source_type": {"type": "string", "enum": ["pdf", "csv", "web", "filing", "registry", "court_docket", "api", "other"]},
    "source_name": {"type": "string", "minLength": 1},
    "source_path_or_url": {"type": "string"},
    "page_or_line_ref": {"type": "string"},
    "claim": {"type": "string", "minLength": 1},
    "evidence_tier": {"type": "string", "enum": ["T1", "T2", "T3", "T4"]},
    "extraction_method": {"type": "string", "enum": ["manual", "parser", "OCR", "API", "web", "other"]},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "review_status": {"type": "string", "enum": ["accepted", "pending", "rejected"]}
  },
  "additionalProperties": true
}
