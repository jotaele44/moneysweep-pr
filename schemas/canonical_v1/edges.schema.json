{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical_v1/edges.schema.json",
  "title": "Canonical v1 — Edge",
  "description": "A typed, evidence-backed graph edge in Canonical Entity Relationship Model v1.",
  "type": "object",
  "required": [
    "edge_id", "source_node_type", "source_node_id", "edge_type",
    "target_node_type", "target_node_id", "confidence", "evidence_id"
  ],
  "properties": {
    "edge_id": {"type": "string", "pattern": "^edge_[A-Za-z0-9_]+$"},
    "source_node_type": {"type": "string", "enum": ["Person", "Entity", "Contract", "Project", "DebtInstrument", "LobbyingRecord", "FundingSource", "Property", "Municipality"]},
    "source_node_id": {"type": "string", "minLength": 1},
    "edge_type": {"type": "string", "enum": [
      "HOLDS_ROLE_IN", "OWNS_OR_CONTROLS", "REPRESENTS", "ADVISES",
      "RECEIVES_CONTRACT", "FUNDED_BY", "LOCATED_IN", "HOLDS_DEBT",
      "NEGOTIATES_WITH", "SHARES_PERSONNEL_WITH", "LOBBIES_FOR", "BENEFITS_FROM",
      "COLLECTS_REVENUE", "ALLOCATES_REVENUE_TO", "PLEDGED_TO_DEBT"
    ]},
    "target_node_type": {"type": "string", "enum": ["Person", "Entity", "Contract", "Project", "DebtInstrument", "LobbyingRecord", "FundingSource", "Property", "Municipality"]},
    "target_node_id": {"type": "string", "minLength": 1},
    "start_date": {"type": "string"},
    "end_date": {"type": "string"},
    "amount": {"type": "number", "minimum": 0.0},
    "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "evidence_id": {"type": "string", "pattern": "^evidence_[A-Za-z0-9_]+$"},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
