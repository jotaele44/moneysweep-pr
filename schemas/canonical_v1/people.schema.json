{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical_v1/people.schema.json",
  "title": "Canonical v1 — Person",
  "description": "An individual actor in the Canonical Entity Relationship Model v1.",
  "type": "object",
  "required": ["person_id", "full_name", "normalized_name", "confidence"],
  "properties": {
    "person_id": {"type": "string", "pattern": "^person_[A-Za-z0-9_]+$"},
    "full_name": {"type": "string", "minLength": 1},
    "normalized_name": {"type": "string", "minLength": 1},
    "aliases": {"type": "string"},
    "primary_role": {"type": "string"},
    "primary_entity_id": {"type": "string", "pattern": "^entity_[A-Za-z0-9_]+$"},
    "jurisdiction": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "evidence_id": {"type": "string", "pattern": "^evidence_[A-Za-z0-9_]+$"},
    "review_status": {"type": "string", "enum": ["accepted", "pending", "rejected"]},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
