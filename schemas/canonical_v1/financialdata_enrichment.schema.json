{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical_v1/financialdata_enrichment.schema.json",
  "title": "FinancialData.net enrichment row",
  "description": "Normalized output row from the OPTIONAL FinancialData.net commercial provider adapter. Used for public-market entity resolution (CUSIP/ISIN/FIGI/LEI/CIK/ticker crosswalks). Default disabled; live use requires both FINANCIALDATA_API_KEY and FINANCIALDATA_LICENSE_APPROVED.",
  "type": "object",
  "required": [
    "source_entity_id",
    "provider",
    "match_method",
    "confidence",
    "review_required",
    "evidence_tier",
    "retrieved_at",
    "license_status",
    "raw_payload_stored"
  ],
  "properties": {
    "source_entity_id":     {"type": "string", "minLength": 1},
    "source_entity_name":   {"type": ["string", "null"]},
    "source_family":        {"type": ["string", "null"]},
    "provider":             {"type": "string", "const": "financialdata_net"},
    "provider_endpoint":    {
      "type": "string",
      "enum": [
        "company_information",
        "securities_information",
        "institutional_holdings",
        "investment_adviser_information",
        "none"
      ]
    },
    "provider_identifier":  {"type": ["string", "null"]},
    "matched_name":         {"type": ["string", "null"]},
    "ticker":               {"type": ["string", "null"]},
    "cik":                  {"type": ["string", "null"]},
    "lei":                  {"type": ["string", "null"]},
    "cusip":                {"type": ["string", "null"]},
    "isin":                 {"type": ["string", "null"]},
    "figi":                 {"type": ["string", "null"]},
    "security_type":        {"type": ["string", "null"]},
    "industry":             {"type": ["string", "null"]},
    "website":              {"type": ["string", "null"]},
    "country":              {"type": ["string", "null"]},
    "match_method": {
      "type": "string",
      "enum": [
        "deterministic_cusip",
        "deterministic_isin",
        "deterministic_figi",
        "deterministic_lei",
        "deterministic_cik",
        "deterministic_ticker",
        "exact_name",
        "fuzzy_name",
        "ambiguous_multi",
        "unmatched",
        "not_public_market_resolved"
      ]
    },
    "confidence":      {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "review_required": {"type": "boolean"},
    "evidence_tier":   {"type": "string", "enum": ["T1", "T2", "T3", "T4"]},
    "retrieved_at":    {"type": "string", "minLength": 1},
    "license_status":  {"type": "string", "enum": ["approved", "not_approved", "unknown"]},
    "raw_payload_stored": {"type": "boolean", "default": false}
  },
  "additionalProperties": false
}
