{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical_v1/lobbying_records.schema.json",
  "title": "Canonical v1 — Lobbying Record",
  "description": "A PR cabildero or federal LDA lobbying filing in Canonical Entity Relationship Model v1.",
  "type": "object",
  "required": ["lobbying_record_id", "jurisdiction", "filing_type", "confidence"],
  "properties": {
    "lobbying_record_id": {"type": "string", "pattern": "^lobby_[A-Za-z0-9_]+$"},
    "jurisdiction": {"type": "string", "enum": ["PR", "federal"]},
    "registration_number": {"type": "string"},
    "period": {"type": "string"},
    "lobbyist_entity_id": {"type": "string", "pattern": "^entity_[A-Za-z0-9_]+$"},
    "client_entity_id": {"type": "string", "pattern": "^entity_[A-Za-z0-9_]+$"},
    "authorized_personnel": {"type": "string"},
    "subject_matter": {"type": "string"},
    "amount": {"type": "number", "minimum": 0.0},
    "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "filing_type": {"type": "string", "enum": ["LDA", "PR_cabildero"]},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "evidence_id": {"type": "string", "pattern": "^evidence_[A-Za-z0-9_]+$"},
    "review_status": {"type": "string", "enum": ["accepted", "pending", "rejected"]},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
