{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical_v1/contracts.schema.json",
  "title": "Canonical v1 — Contract",
  "description": "A public contract, amendment, or award in Canonical Entity Relationship Model v1.",
  "type": "object",
  "required": ["contract_id", "awarding_entity_id", "currency", "confidence"],
  "properties": {
    "contract_id": {"type": "string", "pattern": "^contract_[A-Za-z0-9_]+$"},
    "contract_number": {"type": "string"},
    "awarding_entity_id": {"type": "string", "pattern": "^entity_[A-Za-z0-9_]+$"},
    "contractor_entity_id": {"type": "string", "pattern": "^entity_[A-Za-z0-9_]+$"},
    "project_id": {"type": "string", "pattern": "^project_[A-Za-z0-9_]+$"},
    "service_type": {"type": "string"},
    "award_amount": {"type": "number", "minimum": 0.0},
    "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "start_date": {"type": "string"},
    "end_date": {"type": "string"},
    "status": {"type": "string", "enum": ["award", "amendment", "active", "completed", "terminated", "other"]},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "evidence_id": {"type": "string", "pattern": "^evidence_[A-Za-z0-9_]+$"},
    "review_status": {"type": "string", "enum": ["accepted", "pending", "rejected"]},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
