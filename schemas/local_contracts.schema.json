{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Puerto Rico Local Contract Row",
  "type": "object",
  "required": [
    "contract_id",
    "source_id",
    "agency",
    "contract_number",
    "contractor_name_raw",
    "amount",
    "service_type",
    "source_file",
    "evidence_tier",
    "confidence"
  ],
  "properties": {
    "contract_id": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "minLength": 1},
    "agency": {"type": "string", "minLength": 1},
    "contract_number": {"type": "string", "minLength": 1},
    "parent_contract_number": {"type": "string"},
    "amendment_number": {"type": "string"},
    "contractor_name_raw": {"type": "string", "minLength": 1},
    "contractor_entity_id": {"type": "string"},
    "award_date": {"type": "string"},
    "start_date": {"type": "string"},
    "end_date": {"type": "string"},
    "amount": {"type": "number"},
    "currency": {"type": "string", "default": "USD"},
    "service_type": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "municipality": {"type": "string"},
    "funding_source": {"type": "string"},
    "procurement_method": {"type": "string"},
    "status": {"type": "string"},
    "source_file": {"type": "string", "minLength": 1},
    "source_page": {"type": "string"},
    "evidence_tier": {"type": "string", "enum": ["T1", "T2", "T3", "T4"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "extraction_notes": {"type": "string"}
  },
  "additionalProperties": true
}
