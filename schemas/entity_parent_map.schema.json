{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entity Parent Map Row",
  "type": "object",
  "required": [
    "relation_id",
    "parent_entity_id",
    "child_entity_id",
    "relationship_type",
    "evidence_tier",
    "confidence"
  ],
  "properties": {
    "relation_id": {
      "type": "string",
      "pattern": "^REL_PARENT_[A-Za-z0-9_.:-]+$"
    },
    "parent_entity_id": {
      "type": "string",
      "pattern": "^ENT_(ORG|PERSON|AGENCY|MUNI|PROJECT|CONTRACT|DEBT|PROPERTY|ASSET)_[A-Za-z0-9_.:-]+$"
    },
    "child_entity_id": {
      "type": "string",
      "pattern": "^ENT_(ORG|PERSON|AGENCY|MUNI|PROJECT|CONTRACT|DEBT|PROPERTY|ASSET)_[A-Za-z0-9_.:-]+$"
    },
    "relationship_type": {
      "type": "string",
      "enum": ["INSTRUMENTALITY_OF", "P3_OPERATOR_OF", "CONCESSION_OPERATOR_OF", "SUBSIDIARY_OF"]
    },
    "source_id": {"type": "string", "minLength": 1},
    "evidence_tier": {"type": "string", "enum": ["T1", "T2", "T3", "T4"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
