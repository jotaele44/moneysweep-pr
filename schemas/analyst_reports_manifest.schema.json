{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Analyst Report Catalog Entry",
  "type": "object",
  "required": [
    "report_id",
    "title",
    "gate",
    "path",
    "format",
    "status",
    "row_count"
  ],
  "properties": {
    "report_id": {"type": "string", "pattern": "^RPT_[A-Za-z0-9_.:-]+$"},
    "title": {"type": "string", "minLength": 1},
    "gate": {"type": "string", "minLength": 1},
    "path": {"type": "string", "minLength": 1},
    "format": {"type": "string", "enum": ["csv", "json", "html", "md"]},
    "producer_script": {"type": "string"},
    "schema": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["done", "partial", "missing", "blocked", "manual_required", "auth_required", "unknown"]
    },
    "row_count": {"type": "integer", "minimum": 0}
  },
  "additionalProperties": true
}
