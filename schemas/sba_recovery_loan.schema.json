{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SBARecoveryLoan",
  "type": "object",
  "required": [
    "source_id",
    "source_file",
    "record_id",
    "loan_type",
    "fema_disaster_number",
    "sba_disaster_number",
    "municipality",
    "approved_loan_amount",
    "raw_sheet",
    "raw_row_number",
    "evidence_tier",
    "confidence"
  ],
  "properties": {
    "source_id": {"type": "string", "const": "sba_disaster_loans_pr"},
    "source_file": {"type": "string"},
    "record_id": {"type": "string"},
    "loan_type": {"type": "string", "enum": ["home", "business"]},
    "physical_declaration_number": {"type": ["string", "null"]},
    "eidl_declaration_number": {"type": ["string", "null"]},
    "fema_disaster_number": {"type": "string"},
    "sba_disaster_number": {"type": "string"},
    "damaged_property_city": {"type": ["string", "null"]},
    "zip_code": {"type": ["string", "null"]},
    "municipality": {"type": "string"},
    "verified_loss_amount": {"type": ["number", "null"], "minimum": 0},
    "approved_loan_amount": {"type": "number", "minimum": 0},
    "eidl_amount": {"type": ["number", "null"], "minimum": 0},
    "fiscal_year": {"type": ["integer", "null"]},
    "report_run_date": {"type": ["string", "null"]},
    "raw_sheet": {"type": "string"},
    "raw_row_number": {"type": "integer", "minimum": 1},
    "evidence_tier": {"type": "string", "enum": ["T1"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  },
  "additionalProperties": false
}
