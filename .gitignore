# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.DS_Store

# Secrets — NEVER commit
.env
*.key

# Data files (downloaded CSVs — too large for git)
data/staging/expansion/*.csv
data/staging/processed/*.csv
data/staging/processed/*.parquet
data/staging/normalized/*.csv
