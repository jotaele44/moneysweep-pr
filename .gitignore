# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Coverage reports
.coverage
coverage.xml
htmlcov/

# Secrets — NEVER commit
.env
*.key

# Data files (downloaded CSVs / normalized outputs — too large for git)
data/staging/expansion/*.csv
data/staging/processed/**
data/staging/raw/**/*.csv
data/raw/*.csv
data/normalized/

# Large raw acquisitions (untracked blobs — keep out going forward). These are the
# heavyweight raw drops; curated small CSVs and tracked reference PDFs under
# data/raw/** stay tracked. Status reports are data-presence derived, so we only
# untrack inputs that are NOT declared as any source's expected_output.
data/raw/Follow the Money/funding_flows_sf133.csv
data/raw/FEC/*.csv

# Logs
data/logs/*.log

# On-demand query cache (parquet bodies + sidecar manifests)
data/cache/

# Enrichment outputs (may contain vendor PII)
data/staging/processed/enrichment/

# Keep structure files
!data/**/.gitkeep
!data/staging/processed/.gitkeep
!data/staging/expansion/DOWNLOAD_INSTRUCTIONS.md
!data/staging/expansion/manifest.json
data/raw/Grants/*.xml

# Local raw source acquisitions
/data/raw/USAS/

# Triaged document corpus — keep the manifest + index tracked, ignore binaries
data/raw/documents/**/*.pdf
data/raw/documents/**/*.txt
.claude/

# Machine-specific cypher-shell discovery output emitted by PREPA load launchers
outputs/**/cypher_shell_candidates.txt
