# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Coverage reports
.coverage
coverage.xml
htmlcov/

# Secrets — NEVER commit
.env
*.key

# Data — deny-all by default, then allow tracked artifact subtrees (RECS #2).
# Previous path-by-path denylist let blobs slip through when paths contained
# spaces or new nested dirs. The deny-all is the defensive posture; the
# explicit allow-list below is the policy for what's deliberately tracked.
#
# IMPORTANT: gitignore rules are order-sensitive and *later wins*. The deny-all
# `data/**` excludes subdirectories themselves, so every re-included subtree
# needs BOTH the directory un-ignore (`!data/<dir>/`) AND the contents
# un-ignore (`!data/<dir>/**`), and both must come AFTER `data/**`.

# Deny-all under data/ as the defensive posture
data/**

# Directory un-ignores (so git descends into these dirs; must come AFTER data/**)
!data/canonical_v1/
!data/exports/
!data/manifests/
!data/processed/
!data/reference/
!data/reports/
!data/review_queue/
!data/staging/
!data/staging/expansion/
!data/raw/
!data/raw/act_transition/
!data/raw/HigherGov/
!data/raw/documents/
!data/raw/follow_the_money/
!data/raw/torres_rosa_consultation/

# Content un-ignores for tracked artifact subtrees (small JSONs / manifests /
# status reports that are part of the audit trail and intentionally committed).
!data/canonical_v1/**
!data/exports/**
!data/manifests/**
!data/processed/**
!data/reference/**
!data/reports/**
!data/review_queue/**
!data/staging/expansion/DOWNLOAD_INSTRUCTIONS.md
!data/staging/expansion/manifest.json
!data/**/.gitkeep

# Specific tracked raw drops (manual-source intakes already in history)
!data/raw/act_transition/**
!data/raw/HigherGov/**
!data/raw/documents/manifest.json
!data/raw/documents/index.csv
!data/raw/follow_the_money/**.json
!data/raw/follow_the_money/**.md
!data/raw/torres_rosa_consultation/**

# Within allowed subtrees, still keep out enrichment outputs (may contain PII)
data/staging/processed/enrichment/**

# Logs and query cache stay out
data/logs/**
data/cache/**
.claude/

# Machine-specific cypher-shell discovery output emitted by PREPA load launchers
outputs/**/cypher_shell_candidates.txt
