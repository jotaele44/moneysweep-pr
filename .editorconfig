# EditorConfig — https://editorconfig.org
# Kept consistent with the ruff config in pyproject.toml ([tool.ruff]
# line-length = 100, target py310) so editors and the formatter agree.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.py]
indent_size = 4
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.md]
# Markdown is whitespace-sensitive: a hard wrap and two trailing spaces both
# carry meaning, so don't let editors strip them.
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab
